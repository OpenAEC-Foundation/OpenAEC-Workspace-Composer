{
  "permissions": {
    "allow": [
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "Bash(gh api:*)",
      "Bash(gh repo:*)",
      "Bash(python -m base64 -d)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/ensure-dev-running.sh"
          }
        ]
      }
    ]
  }
}
